<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="347.0" prefWidth="302.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.topic7_benavidez.Controller">
   <center>
      <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <VBox prefHeight="101.0" prefWidth="247.0">
               <children>
                  <TextField fx:id="txtName" prefHeight="25.0" prefWidth="135.0">
                     <VBox.margin>
                        <Insets left="20.0" right="20.0" />
                     </VBox.margin>
                  </TextField>
                  <TextField fx:id="txtCourse">
                     <VBox.margin>
                        <Insets left="20.0" right="20.0" />
                     </VBox.margin>
                  </TextField>
                  <ChoiceBox fx:id="cbYear" prefHeight="25.0" prefWidth="191.0">
                     <VBox.margin>
                        <Insets left="20.0" right="20.0" />
                     </VBox.margin>
                  </ChoiceBox>
               </children>
            </VBox>
            <VBox prefHeight="200.0" prefWidth="100.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#addStudent" text="Add" />
                  <Button mnemonicParsing="false" onAction="#updateStudent" text="Update" />
                  <Button mnemonicParsing="false" onAction="#deleteStudent" text="Delete" />
                  <Button mnemonicParsing="false" onAction="#clearFields" text="Clear" />
               </children>
            </VBox>
         </children>
      </HBox>
   </center>
   <bottom>
      <TableView fx:id="table" prefHeight="250.0" prefWidth="350.0" BorderPane.alignment="CENTER">
         <columns>
            <TableColumn fx:id="colId" prefWidth="75.0" text="ID" />
            <TableColumn fx:id="colName" prefWidth="75.0" text="Name" />
            <TableColumn fx:id="colCourse" prefWidth="75.0" text="Course" />

                        <TableColumn fx:id="colYear" prefWidth="75.0" text="Year Level" />
         </columns>
      </TableView>
   </bottom>
</BorderPane>
